<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="InsideOS.App"
             RequestedThemeVariant="Dark">

    <Application.Resources>
        <!-- Palette -->
        <SolidColorBrush x:Key="BrushBgContent" Color="#16181E"/>
        <SolidColorBrush x:Key="BrushBgSidebar" Color="#111319"/>
        <SolidColorBrush x:Key="BrushHairline" Color="#242933"/>
        <SolidColorBrush x:Key="BrushCard" Color="#0AFFFFFF"/>
        <SolidColorBrush x:Key="BrushCardBorder" Color="#12FFFFFF"/>
        <SolidColorBrush x:Key="BrushTextPrimary" Color="#EDEFF4"/>
        <SolidColorBrush x:Key="BrushTextSecondary" Color="#9AA3B4"/>
        <SolidColorBrush x:Key="BrushTextMuted" Color="#656F82"/>
        <SolidColorBrush x:Key="BrushAccent" Color="#4D9FFF"/>
        <SolidColorBrush x:Key="BrushAccentSoft" Color="#1F4D9FFF"/>
        <SolidColorBrush x:Key="BrushAccentBorder" Color="#364D9FFF"/>
        <SolidColorBrush x:Key="BrushSuccess" Color="#3FBF7F"/>
        <LinearGradientBrush x:Key="BrushLogo" StartPoint="0%,0%" EndPoint="100%,100%">
            <GradientStop Offset="0" Color="#4D9FFF"/>
            <GradientStop Offset="1" Color="#7A5CFF"/>
        </LinearGradientBrush>

        <!-- Icons (24x24 stroke geometries) -->
        <StreamGeometry x:Key="IconPulse">M22 12h-4l-3 9L9 3l-3 9H2</StreamGeometry>
        <StreamGeometry x:Key="IconBook">M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2zM22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z</StreamGeometry>
        <StreamGeometry x:Key="IconLock">M5 11h14a2 2 0 0 1 2 2v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2zM7 11V7a5 5 0 0 1 10 0v4</StreamGeometry>
        <StreamGeometry x:Key="IconTimeline">M12 2a10 10 0 1 0 0 20a10 10 0 1 0 0-20M12 6v6l4 2</StreamGeometry>
        <StreamGeometry x:Key="IconFlow">M6 3v12M18 3a3 3 0 1 0 0 6a3 3 0 1 0 0-6M6 15a3 3 0 1 0 0 6a3 3 0 1 0 0-6M18 9a9 9 0 0 1-9 9</StreamGeometry>
        <StreamGeometry x:Key="IconMetrics">M12 20V10M18 20V4M6 20v-4</StreamGeometry>
        <StreamGeometry x:Key="IconCheck">M4 12.5l5.5 5.5L20 6.5</StreamGeometry>
        <StreamGeometry x:Key="IconBulb">M15 14c.2-1 .7-1.7 1.5-2.5a7 7 0 1 0-9 0c.8.8 1.3 1.5 1.5 2.5M9 18h6M10 22h4</StreamGeometry>
        <StreamGeometry x:Key="IconGlobe">M12 2a10 10 0 1 0 0 20a10 10 0 1 0 0-20M2 12h20M12 2a15.3 15.3 0 0 1 4 10a15.3 15.3 0 0 1-4 10a15.3 15.3 0 0 1-4-10a15.3 15.3 0 0 1 4-10</StreamGeometry>
        <StreamGeometry x:Key="IconAppWindow">M4 4h16a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2zM2 9h20</StreamGeometry>
        <StreamGeometry x:Key="IconProcesses">M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01</StreamGeometry>
        <StreamGeometry x:Key="IconGauge">M12 14l4-4M3.34 19a10 10 0 1 1 17.32 0</StreamGeometry>
        <StreamGeometry x:Key="IconMemChip">M6 19v-3M10 19v-3M14 19v-3M18 19v-3M8 11V9M16 11V9M12 11V9M2 15h20M2 7a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v1.1a2 2 0 0 0 0 3.837V17a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1v-5.1a2 2 0 0 0 0-3.837Z</StreamGeometry>
        <StreamGeometry x:Key="IconDisk">M22 12H2M5.45 5.11L2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11zM6 16h.01M10 16h.01</StreamGeometry>
        <StreamGeometry x:Key="IconDownload">M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3</StreamGeometry>
        <StreamGeometry x:Key="IconUpload">M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M17 8l-5-5-5 5M12 3v12</StreamGeometry>
        <StreamGeometry x:Key="IconBattery">M4 7h12a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V9a2 2 0 0 1 2-2zM22 11v2M6 11v2M10 11v2</StreamGeometry>
        <StreamGeometry x:Key="IconTimer">M10 2h4M12 14l3-3M12 6a8 8 0 1 0 0 16a8 8 0 1 0 0-16</StreamGeometry>
        <StreamGeometry x:Key="IconMonitor">M4 3h16a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2zM8 21h8M12 17v4</StreamGeometry>
        <StreamGeometry x:Key="IconCpuChip">M6 4h12a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2zM9 9h6v6H9zM9 1v3M15 1v3M9 20v3M15 20v3M20 9h3M20 14h3M1 9h3M1 14h3</StreamGeometry>
        <StreamGeometry x:Key="IconSettings">M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2zM12 9a3 3 0 1 0 0 6a3 3 0 1 0 0-6</StreamGeometry>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />

        <!-- Page header -->
        <Style Selector="TextBlock.pageTitle">
            <Setter Property="FontSize" Value="26"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
        </Style>
        <Style Selector="TextBlock.pageSubtitle">
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}"/>
        </Style>

        <!-- Placeholder card -->
        <Style Selector="Border.placeholderCard">
            <Setter Property="Background" Value="{StaticResource BrushCard}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushCardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
        </Style>
        <Style Selector="Border.placeholderIconBox">
            <Setter Property="Width" Value="48"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="CornerRadius" Value="13"/>
            <Setter Property="Background" Value="{StaticResource BrushAccentSoft}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushAccentBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
        <Style Selector="Path.pageIcon">
            <Setter Property="Stroke" Value="{StaticResource BrushAccent}"/>
            <Setter Property="StrokeThickness" Value="1.8"/>
            <Setter Property="StrokeLineCap" Value="Round"/>
            <Setter Property="StrokeJoin" Value="Round"/>
        </Style>
        <Style Selector="TextBlock.placeholderTitle">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>
        <!-- Buttons -->
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="{StaticResource BrushAccent}"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="CornerRadius" Value="9"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.primary:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#63AEFF"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
        </Style>
        <Style Selector="Button.primary:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#3B8BEE"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
        </Style>
        <Style Selector="Button.ghost">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#2BFFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}"/>
            <Setter Property="CornerRadius" Value="9"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.ghost:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#10FFFFFF"/>
            <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
        </Style>
        <Style Selector="Button.ghost:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#18FFFFFF"/>
            <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
        </Style>

        <!-- Section labels -->
        <Style Selector="TextBlock.sectionLabel">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="LetterSpacing" Value="1.2"/>
            <Setter Property="Foreground" Value="{StaticResource BrushTextMuted}"/>
        </Style>

        <!-- Metric dashboard cards -->
        <Style Selector="Border.metricCard">
            <Setter Property="Background" Value="{StaticResource BrushCard}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushCardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.metricCard:pointerover">
            <Setter Property="BorderBrush" Value="#26FFFFFF"/>
        </Style>
        <Style Selector="Border.metricIconBox">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Background" Value="{StaticResource BrushAccentSoft}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushAccentBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="Path.metricIcon">
            <Setter Property="Stroke" Value="{StaticResource BrushAccent}"/>
            <Setter Property="StrokeThickness" Value="1.8"/>
            <Setter Property="StrokeLineCap" Value="Round"/>
            <Setter Property="StrokeJoin" Value="Round"/>
        </Style>
        <Style Selector="TextBlock.metricTitle">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}"/>
        </Style>
        <Style Selector="TextBlock.metricValue">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style Selector="TextBlock.metricSubtitle">
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="Foreground" Value="{StaticResource BrushTextMuted}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="LineHeight" Value="16"/>
        </Style>

        <Style Selector="TextBlock.placeholderBody">
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Foreground" Value="{StaticResource BrushTextMuted}"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="LineHeight" Value="19"/>
        </Style>
    </Application.Styles>
</Application>
