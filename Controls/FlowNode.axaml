<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="InsideOS.Controls.FlowNode"
             Width="190" Height="112">

    <UserControl.Styles>
        <!-- Breathing glow: speed follows the node's activity level -->
        <Style Selector="Border#GlowLayer">
            <Setter Property="Opacity" Value="0.10"/>
        </Style>
        <Style Selector="Border#GlowLayer.pulseCalm">
            <Style.Animations>
                <Animation Duration="0:0:4" IterationCount="Infinite">
                    <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0.08"/></KeyFrame>
                    <KeyFrame Cue="50%"><Setter Property="Opacity" Value="0.18"/></KeyFrame>
                    <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0.08"/></KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <Style Selector="Border#GlowLayer.pulseActive">
            <Style.Animations>
                <Animation Duration="0:0:2.6" IterationCount="Infinite">
                    <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0.10"/></KeyFrame>
                    <KeyFrame Cue="50%"><Setter Property="Opacity" Value="0.26"/></KeyFrame>
                    <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0.10"/></KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <Style Selector="Border#GlowLayer.pulseBusy">
            <Style.Animations>
                <Animation Duration="0:0:1.6" IterationCount="Infinite">
                    <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0.12"/></KeyFrame>
                    <KeyFrame Cue="50%"><Setter Property="Opacity" Value="0.34"/></KeyFrame>
                    <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0.12"/></KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>

        <Style Selector="Border#ActivityGlow">
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.8" Easing="CubicEaseOut"/>
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Border#CardLayer">
            <Setter Property="Background" Value="#1A1E28"/>
            <Setter Property="BorderBrush" Value="#1FFFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BoxShadow" Value="0 6 18 0 #33000000"/>
            <Setter Property="RenderTransform" Value="scale(1)"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.15"/>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.16" Easing="CubicEaseOut"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border#CardLayer:pointerover">
            <Setter Property="BorderBrush" Value="#664D9FFF"/>
            <Setter Property="RenderTransform" Value="scale(1.03)"/>
        </Style>
    </UserControl.Styles>

    <Panel>
        <Border x:Name="ActivityGlow" CornerRadius="26" Background="#4D9FFF"/>
        <Border x:Name="GlowLayer" CornerRadius="22" Background="#4D9FFF" Margin="2"/>
        <Border x:Name="SpotlightRing" BorderBrush="#904D9FFF" BorderThickness="2"
                CornerRadius="15" Margin="5" IsHitTestVisible="False" Opacity="0"
                BoxShadow="0 0 22 2 #554D9FFF">
            <Border.Transitions>
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.3" Easing="CubicEaseOut"/>
                </Transitions>
            </Border.Transitions>
        </Border>
        <Border x:Name="CardLayer" Margin="8">
            <StackPanel Margin="13,10,13,0">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Border Width="24" Height="24" CornerRadius="7"
                            Background="{StaticResource BrushAccentSoft}"
                            BorderBrush="{StaticResource BrushAccentBorder}" BorderThickness="1">
                        <Viewbox Width="12" Height="12"
                                 HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Path x:Name="IconPath" Width="24" Height="24" Classes="metricIcon"/>
                        </Viewbox>
                    </Border>
                    <TextBlock x:Name="TitleText" FontSize="11.5" FontWeight="Medium"
                               Foreground="{StaticResource BrushTextSecondary}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock x:Name="ValueText" FontSize="19" FontWeight="SemiBold"
                           Foreground="{StaticResource BrushTextPrimary}"
                           Margin="0,6,0,0" TextTrimming="CharacterEllipsis" Text="—"
                           RenderTransform="translateY(0px)">
                    <TextBlock.Transitions>
                        <Transitions>
                            <DoubleTransition Property="Opacity" Duration="0:0:0.28" Easing="CubicEaseOut"/>
                            <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.28" Easing="CubicEaseOut"/>
                        </Transitions>
                    </TextBlock.Transitions>
                </TextBlock>

                <Grid ColumnDefinitions="Auto,*" Margin="0,5,0,0">
                    <Border x:Name="BadgePill" CornerRadius="99" Padding="7,2"
                            BorderThickness="1" IsVisible="False"
                            VerticalAlignment="Center">
                        <TextBlock x:Name="BadgeText" FontSize="8.5" FontWeight="SemiBold"
                                   LetterSpacing="0.8"/>
                    </Border>
                    <TextBlock Grid.Column="1" x:Name="MetaText" FontSize="10"
                               Foreground="{StaticResource BrushTextMuted}"
                               Margin="6,0,0,0" VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" IsVisible="False"/>
                </Grid>
            </StackPanel>
        </Border>
    </Panel>
</UserControl>
