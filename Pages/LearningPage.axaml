<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="620"
             x:Class="InsideOS.Pages.LearningPage">

    <UserControl.Styles>
        <!-- Lesson library cards -->
        <Style Selector="Border.lessonCard">
            <Setter Property="Background" Value="{StaticResource BrushCard}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushCardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16,13"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.14"/>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.14"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.lessonCard.open">
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Border.lessonCard.open:pointerover">
            <Setter Property="Background" Value="#10FFFFFF"/>
            <Setter Property="BorderBrush" Value="#22FFFFFF"/>
        </Style>
        <Style Selector="Border.lessonCard.locked">
            <Setter Property="Opacity" Value="0.55"/>
        </Style>

        <!-- Small meta chips on the details view -->
        <Style Selector="Border.metaChip">
            <Setter Property="Background" Value="#0DFFFFFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushHairline}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="99"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="Border.metaChip TextBlock">
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*" Margin="32,28,32,28">
        <StackPanel Spacing="6">
            <TextBlock Classes="pageTitle" Text="Learning Journey"/>
            <TextBlock Classes="pageSubtitle"
                       Text="Structured lessons that teach you how your operating system really works."/>
        </StackPanel>

        <Panel Grid.Row="1" Margin="0,24,0,0">

            <!-- ===== Lesson library ===== -->
            <ScrollViewer x:Name="LibraryView" HorizontalScrollBarVisibility="Disabled">
                <ScrollViewer.Transitions>
                    <Transitions>
                        <DoubleTransition Property="Opacity" Duration="0:0:0.16"/>
                    </Transitions>
                </ScrollViewer.Transitions>
                <StackPanel Spacing="12" MaxWidth="640" HorizontalAlignment="Left"
                            Margin="0,0,0,24">

                    <!-- Overall progress -->
                    <Border Classes="metricCard" Padding="18">
                        <StackPanel Spacing="12">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock x:Name="ProgressText"
                                           FontSize="13.5" FontWeight="Medium"
                                           Foreground="{StaticResource BrushTextPrimary}"/>
                                <TextBlock x:Name="ProgressPercentText" Grid.Column="1"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource BrushAccent}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                            <ProgressBar x:Name="JourneyBar"
                                         Height="4" MinHeight="4" CornerRadius="2"
                                         Minimum="0" Maximum="100" Value="0"
                                         Background="#14FFFFFF"
                                         Foreground="{StaticResource BrushAccent}">
                                <ProgressBar.Transitions>
                                    <Transitions>
                                        <DoubleTransition Property="Value" Duration="0:0:0.5" Easing="CubicEaseOut"/>
                                    </Transitions>
                                </ProgressBar.Transitions>
                            </ProgressBar>
                        </StackPanel>
                    </Border>

                    <TextBlock Classes="sectionLabel" Text="LESSONS" Margin="0,10,0,0"/>

                    <!-- Cards are built from the LessonManager catalog -->
                    <StackPanel x:Name="LessonCards" Spacing="10"/>
                </StackPanel>
            </ScrollViewer>

            <!-- ===== Lesson details ===== -->
            <ScrollViewer x:Name="DetailsView" IsVisible="False" Opacity="0"
                          HorizontalScrollBarVisibility="Disabled">
                <ScrollViewer.Transitions>
                    <Transitions>
                        <DoubleTransition Property="Opacity" Duration="0:0:0.16"/>
                        <TransformOperationsTransition Property="RenderTransform"
                                                       Duration="0:0:0.22" Easing="CubicEaseOut"/>
                    </Transitions>
                </ScrollViewer.Transitions>
                <StackPanel Spacing="14" MaxWidth="640" HorizontalAlignment="Left"
                            Margin="0,0,0,24">
                    <Button Classes="ghost" Content="←  All Lessons" Padding="12,6"
                            Click="OnBack"/>

                    <Border Classes="metricCard" Padding="24">
                        <StackPanel Spacing="14">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock x:Name="DetailKicker"
                                           FontSize="10.5" FontWeight="SemiBold" LetterSpacing="1.2"
                                           Foreground="{StaticResource BrushTextMuted}"
                                           VerticalAlignment="Center"/>
                                <Border x:Name="DetailStatusChip" Grid.Column="1"
                                        CornerRadius="99" Padding="9,3,9,4" BorderThickness="1">
                                    <TextBlock x:Name="DetailStatusText"
                                               FontSize="10.5" FontWeight="Medium"/>
                                </Border>
                            </Grid>

                            <TextBlock x:Name="DetailTitle"
                                       FontSize="21" FontWeight="SemiBold"
                                       Foreground="{StaticResource BrushTextPrimary}"/>

                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Border Classes="metaChip">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Viewbox Width="12" Height="12" VerticalAlignment="Center">
                                            <Path Width="24" Height="24"
                                                  Data="{StaticResource IconTimer}"
                                                  Stroke="{StaticResource BrushTextSecondary}"
                                                  StrokeThickness="1.8"
                                                  StrokeLineCap="Round" StrokeJoin="Round"/>
                                        </Viewbox>
                                        <TextBlock x:Name="DetailDuration" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Border Classes="metaChip">
                                    <TextBlock x:Name="DetailDifficulty"/>
                                </Border>
                            </StackPanel>

                            <TextBlock x:Name="DetailDescription"
                                       FontSize="12.5" LineHeight="19" TextWrapping="Wrap"
                                       Foreground="{StaticResource BrushTextSecondary}"/>

                            <Border Height="1" Background="{StaticResource BrushHairline}"/>

                            <TextBlock Classes="sectionLabel" Text="WHAT YOU WILL LEARN"/>
                            <StackPanel x:Name="ObjectivesList" Spacing="9"/>

                            <Border Height="1" Background="{StaticResource BrushHairline}" Margin="0,4,0,0"/>

                            <StackPanel Orientation="Horizontal" Spacing="14">
                                <Button x:Name="StartLessonButton" Classes="primary"
                                        Content="Start Lesson" Click="OnStartLesson"/>
                                <TextBlock x:Name="DetailReplayHint" IsVisible="False"
                                           Text="You can replay this lesson at any time."
                                           FontSize="11.5"
                                           Foreground="{StaticResource BrushTextMuted}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Panel>
    </Grid>
</UserControl>
