<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="620"
             x:Class="InsideOS.Pages.ReplayPage">

    <UserControl.Styles>
        <Style Selector="TextBlock.repBody">
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="LineHeight" Value="18"/>
        </Style>
        <Style Selector="TextBlock.repMuted">
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="Foreground" Value="{StaticResource BrushTextMuted}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="LineHeight" Value="16"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*" Margin="32,28,32,28">
        <StackPanel Spacing="6">
            <TextBlock Classes="pageTitle" Text="Replay"/>
            <TextBlock Classes="pageSubtitle"
                       Text="Travel back to a recorded session — the whole app replays it as if it were happening now."/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" Margin="0,24,0,0" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="12" MaxWidth="680" HorizontalAlignment="Left" Margin="0,0,0,24">

                <!-- No session yet -->
                <StackPanel x:Name="EmptyState" Spacing="14" MaxWidth="420"
                            HorizontalAlignment="Center" Margin="0,60,0,0">
                    <Border Classes="placeholderIconBox">
                        <Viewbox Width="20" Height="20"
                                 HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Path Width="24" Height="24" Classes="pageIcon"
                                  Data="{StaticResource IconReplay}"/>
                        </Viewbox>
                    </Border>
                    <TextBlock Classes="placeholderTitle" Text="Nothing recorded yet"/>
                    <TextBlock Classes="placeholderBody"
                               Text="Run a Laboratory experiment — InsideOS records the whole session automatically, so you can come back here and watch it again from the start."/>
                </StackPanel>

                <!-- Session + transport -->
                <Border x:Name="SessionCard" Classes="metricCard" Padding="20" IsVisible="False">
                    <StackPanel Spacing="12">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Classes="sectionLabel" Text="RECORDED SESSION"/>
                            <TextBlock x:Name="StateChip" Grid.Column="1"
                                       FontSize="10.5" FontWeight="SemiBold" LetterSpacing="1"
                                       VerticalAlignment="Center"/>
                        </Grid>
                        <TextBlock x:Name="SessionTitle"
                                   FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap"
                                   Foreground="{StaticResource BrushTextPrimary}"/>
                        <TextBlock x:Name="SessionMeta" Classes="repMuted"/>

                        <Border Height="1" Background="{StaticResource BrushHairline}"/>

                        <StackPanel Orientation="Horizontal" Spacing="14">
                            <Button x:Name="PlayButton" Classes="primary" Content="▶  Play"
                                    Click="OnPlayPause"/>
                            <Button x:Name="RestartButton" Classes="ghost" Content="Restart"
                                    IsVisible="False" Click="OnRestart"/>
                            <Button x:Name="ExitButton" Classes="ghost" Content="Return to Live"
                                    IsVisible="False" Click="OnExit"/>
                            <TextBlock x:Name="TimeText" FontSize="20" FontWeight="SemiBold"
                                       Foreground="{StaticResource BrushTextPrimary}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Scrubber: the whole session as a draggable timeline,
                             with major events as subtle markers along the track. -->
                        <StackPanel x:Name="ScrubBlock" Spacing="0" IsVisible="False">
                            <Panel>
                                <Slider x:Name="Scrub" Minimum="0" Maximum="1"
                                        Height="34" VerticalAlignment="Center"/>
                                <Canvas x:Name="MarkerCanvas" Height="4" Margin="12,22,12,0"
                                        VerticalAlignment="Top" IsHitTestVisible="False"/>
                            </Panel>
                            <Grid ColumnDefinitions="*,Auto" Margin="2,-2,2,0">
                                <TextBlock Text="0:00" FontSize="10.5"
                                           Foreground="{StaticResource BrushTextMuted}"/>
                                <TextBlock x:Name="EndLabel" Grid.Column="1" FontSize="10.5"
                                           Foreground="{StaticResource BrushTextMuted}"/>
                            </Grid>
                        </StackPanel>

                        <TextBlock x:Name="ReplayHint" Classes="repMuted" IsVisible="False"
                                   Text="While replaying, every page of InsideOS shows this moment — drag the timeline to jump to any second, or open the Timeline, Processes, Metrics or Action Flow and watch the past unfold."/>
                    </StackPanel>
                </Border>

                <!-- Major events -->
                <Border x:Name="EventsCard" Classes="metricCard" Padding="20" IsVisible="False">
                    <StackPanel Spacing="10">
                        <TextBlock Classes="sectionLabel" Text="MAJOR EVENTS"/>
                        <StackPanel x:Name="EventsList" Spacing="7"/>
                        <TextBlock x:Name="EndMark" Text="■  End" FontSize="11.5"
                                   Foreground="{StaticResource BrushTextMuted}"/>
                        <TextBlock x:Name="HiddenNote" IsVisible="False"
                                   FontSize="10.5" LineHeight="14" TextWrapping="Wrap"
                                   Foreground="{StaticResource BrushTextMuted}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
