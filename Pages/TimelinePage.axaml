<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="620"
             x:Class="InsideOS.Pages.TimelinePage">

    <UserControl.Styles>
        <!-- Filter pills -->
        <Style Selector="Border.filterBar">
            <Setter Property="Background" Value="#0DFFFFFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushHairline}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="99"/>
            <Setter Property="Padding" Value="3"/>
        </Style>
        <Style Selector="Border.filterPill">
            <Setter Property="Padding" Value="11,4"/>
            <Setter Property="CornerRadius" Value="99"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.filterPill:pointerover">
            <Setter Property="Background" Value="#0DFFFFFF"/>
        </Style>
        <Style Selector="Border.filterPill.selected">
            <Setter Property="Background" Value="#2E4D9FFF"/>
        </Style>
        <Style Selector="Border.filterPill TextBlock">
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}"/>
        </Style>
        <Style Selector="Border.filterPill.selected TextBlock">
            <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
        </Style>

        <!-- Story cards -->
        <Style Selector="Border.storyCard">
            <Setter Property="Background" Value="{StaticResource BrushCard}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushCardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16,13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BoxShadow" Value="0 4 14 0 #26000000"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.14"/>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.14"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.storyCard:pointerover">
            <Setter Property="Background" Value="#10FFFFFF"/>
            <Setter Property="BorderBrush" Value="#24FFFFFF"/>
        </Style>

        <!-- Live insight cards -->
        <Style Selector="Border.insightCard">
            <Setter Property="Background" Value="{StaticResource BrushCard}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushCardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="12,11"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.14"/>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.14"/>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.25"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.insightCard:pointerover">
            <Setter Property="Background" Value="#10FFFFFF"/>
            <Setter Property="BorderBrush" Value="#22FFFFFF"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,Auto,*" Margin="32,28,32,28">
        <StackPanel Spacing="6">
            <TextBlock Classes="pageTitle" Text="Timeline"/>
            <TextBlock Classes="pageSubtitle"
                       Text="The story of what your operating system has been doing."/>
        </StackPanel>

        <!-- Filters + search -->
        <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto" Margin="0,18,0,0">
            <Border Classes="filterBar" HorizontalAlignment="Left">
                <StackPanel x:Name="FilterBar" Orientation="Horizontal">
                    <Border Classes="filterPill selected" Tag="all" PointerPressed="OnFilterPressed">
                        <TextBlock Text="All"/>
                    </Border>
                    <Border Classes="filterPill" Tag="cpu" PointerPressed="OnFilterPressed">
                        <TextBlock Text="CPU"/>
                    </Border>
                    <Border Classes="filterPill" Tag="memory" PointerPressed="OnFilterPressed">
                        <TextBlock Text="Memory"/>
                    </Border>
                    <Border Classes="filterPill" Tag="disk" PointerPressed="OnFilterPressed">
                        <TextBlock Text="Disk"/>
                    </Border>
                    <Border Classes="filterPill" Tag="network" PointerPressed="OnFilterPressed">
                        <TextBlock Text="Network"/>
                    </Border>
                    <Border Classes="filterPill" Tag="processes" PointerPressed="OnFilterPressed">
                        <TextBlock Text="Processes"/>
                    </Border>
                    <Border Classes="filterPill" Tag="learning" PointerPressed="OnFilterPressed">
                        <TextBlock Text="Learning"/>
                    </Border>
                </StackPanel>
            </Border>
            <TextBox Grid.Column="2" x:Name="SearchBox" Width="200"
                     FontSize="12" CornerRadius="8" VerticalAlignment="Center"
                     PlaceholderText="Search processes…"
                     TextChanged="OnSearchChanged"/>
        </Grid>

        <!-- Timeline + insights -->
        <Grid Grid.Row="2" ColumnDefinitions="*,324" Margin="0,20,0,0">
        <Panel>
            <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="StoryList" MaxWidth="760" HorizontalAlignment="Left"
                            Margin="0,2,0,24"/>
            </ScrollViewer>

            <!-- Educational empty state -->
            <StackPanel x:Name="EmptyState" HorizontalAlignment="Center" VerticalAlignment="Center"
                        Spacing="14" MaxWidth="400">
                <Border Classes="placeholderIconBox">
                    <Viewbox Width="20" Height="20"
                             HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Path Width="24" Height="24" Classes="pageIcon"
                              Data="{StaticResource IconTimeline}"/>
                    </Viewbox>
                </Border>
                <TextBlock x:Name="EmptyTitle" Classes="placeholderTitle"
                           TextAlignment="Center" Text="Your computer is quiet."/>
                <TextBlock x:Name="EmptyBody" Classes="placeholderBody"
                           TextAlignment="Center"
                           Text="Interact with applications to begin discovering what your operating system is doing."/>
            </StackPanel>
        </Panel>

        <!-- ===== System Intelligence panel ===== -->
        <ScrollViewer Grid.Column="1" Margin="22,2,0,0" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="12" Margin="0,0,0,24">
                <Border Classes="metricCard" Padding="16,14">
                    <StackPanel Spacing="9">
                        <TextBlock Text="TODAY'S STORY"
                                   FontSize="10" FontWeight="SemiBold" LetterSpacing="1.2"
                                   Foreground="{StaticResource BrushTextMuted}"/>
                        <StackPanel x:Name="SummaryLines" Spacing="7"/>
                    </StackPanel>
                </Border>

                <TextBlock Classes="sectionLabel" Text="LIVE INSIGHTS" Margin="2,8,0,0"/>
                <StackPanel x:Name="InsightList" Spacing="8"/>
                <TextBlock x:Name="InsightsEmpty" TextWrapping="Wrap" LineHeight="16"
                           FontSize="11.5" Foreground="{StaticResource BrushTextMuted}"
                           Text="Watching your system — insights appear here as activity happens."/>
            </StackPanel>
        </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
